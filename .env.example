# ─── Google Sheets (Client CRM) ───────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# ─── Resend (Email notifications) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONSULTANT_EMAIL=info@nexera.uz

# ─── Contact info (shown on site) ─────────────────────────────────────────
NEXT_PUBLIC_PHONE=+998 90 000 00 00
NEXT_PUBLIC_TELEGRAM_USERNAME=nexera_uz

# ─── Site URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexera.uz

# ─── On-demand revalidation (optional) ─────────────────────────────────────
# Set a random secret and use it in Google Apps Script trigger:
#   POST https://nexera.uz/api/revalidate  with header  x-revalidate-secret: <value>
REVALIDATE_SECRET=change_me_to_a_random_string
